# ===============================================
# CRITICAL: HEALTH DATA PROTECTION
# ===============================================
# NEVER commit health records or personal data!
data/
*.db
*.sqlite
*.sqlite3

# ===============================================
# PRIVATE DOCS
# ===============================================
docs/notes/PATENT_ANALYSIS.md
docs/notes/RESEARCH_IDEAS.md

# ===============================================
# EVAL HARNESS RESULTS (issue #29)
# ===============================================
# Local run output — not reproducible across machines/backends/model
# versions, so not worth tracking in git. The harness code itself is
# tracked; only its output isn't.
eval/results/*.json

# ===============================================
# SECRETS & API KEYS
# ===============================================
.env
.env.local
.env.*.local
secrets/
*.pem
*.key
*.crt
credentials.json
config/secrets.yml

# ===============================================
# ML MODELS & CHECKPOINTS
# ===============================================
# Large model files - use Git LFS or external storage
models/*.bin
models/*.pt
models/*.pth
models/*.safetensors
*.gguf
checkpoints/
wandb/
mlruns/

# Keep model configs and metadata
!models/*.json
!models/*.yaml

# ===============================================
# PYTHON
# ===============================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
ENV/
env.bak/
venv.bak/
.venv/

# Conda
.conda/

# PyInstaller
*.manifest
*.spec

# Unit test / coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.log
.pytest_cache/

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb_checkpoints/

# IPython
profile_default/
ipython_config.py

# ===============================================
# DOCKER
# ===============================================
.dockerignore

