# ===============================================
# HealthSteward Environment Configuration
# ===============================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control!

# ===============================================
# ENVIRONMENT
# ===============================================
ENVIRONMENT=development  # development, staging, production

# ===============================================
# ANTHROPIC CLAUDE API
# ===============================================
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022  # or claude-3-opus-20240229

# API rate limiting
CLAUDE_MAX_TOKENS=4096
CLAUDE_TEMPERATURE=0.7

# ===============================================
# DATABASE (PostgreSQL)
# ===============================================
DB_HOST=localhost  # Use 'db' when running in Docker
DB_PORT=5432
DB_NAME=healthsteward
DB_USER=healthsteward
DB_PASSWORD=change_me_in_production

# Full connection string (alternative to individual params)
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ===============================================
# REDIS (Caching & Task Queue)
# ===============================================
REDIS_HOST=localhost  # Use 'redis' when running in Docker
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=  # Leave empty if no password

# ===============================================
# VECTOR DATABASE (ChromaDB for RAG)
# ===============================================
CHROMA_HOST=localhost  # Use 'chromadb' when running in Docker
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=health_documents

# ===============================================
# MODEL PATHS (Local ML Models)
# ===============================================
# Path to your local 7B model (when you get to that stage)
LOCAL_MODEL_PATH=./data/models/mistral-7b-instruct
QUANTIZED_MODEL_PATH=./data/models/mistral-7b-4bit

# HuggingFace settings
HF_HOME=./data/cache/huggingface
TRANSFORMERS_CACHE=./data/cache/transformers

# ===============================================
# CALENDAR INTEGRATION
# ===============================================
# Google Calendar API (optional)
GOOGLE_CALENDAR_CREDENTIALS_PATH=./config/google_credentials.json
GOOGLE_CALENDAR_TOKEN_PATH=./config/token.json

# Apple Calendar (macOS only)
USE_APPLE_CALENDAR=false

# ===============================================
# SCHEDULING & REMINDERS
# ===============================================
# Interview schedule (cron format: minute hour day month day_of_week)
HEALTH_INTERVIEW_SCHEDULE="0 20 * * *"  # 8 PM daily
MEDICATION_REMINDER_SCHEDULE="0 9,21 * * *"  # 9 AM and 9 PM

# ===============================================
# PRIVACY & SECURITY
# ===============================================
# Encryption key for sensitive data (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=generate_a_secure_key_here

# Session secret (generate with: openssl rand -hex 32)
SESSION_SECRET=generate_a_secure_session_secret

# ===============================================
# LOGGING & MONITORING
# ===============================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=./logs/healthsteward.log

# Weights & Biases (optional, for ML experiment tracking)
WANDB_API_KEY=your_wandb_key_here
WANDB_PROJECT=healthsteward
WANDB_ENABLED=false

# ===============================================
# APPLICATION SETTINGS
# ===============================================
APP_NAME=HealthSteward
APP_VERSION=0.1.0
API_HOST=0.0.0.0
API_PORT=8000

# Enable features
ENABLE_BACKGROUND_TASKS=true
ENABLE_CALENDAR_SYNC=false
ENABLE_MEDICATION_REMINDERS=true

# Data retention (days)
CONVERSATION_HISTORY_RETENTION_DAYS=365
LOG_RETENTION_DAYS=90
