# ===============================================
# HealthSteward Environment Configuration
# ===============================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control!

# ===============================================
# ENVIRONMENT
# ===============================================
ENVIRONMENT=development  # development, staging, production

# ===============================================
# LLM PROVIDER (DEC-016)
# ===============================================
# "ollama" (default, local-first — nothing leaves your machine), "claude",
# or "custom" (any OpenAI-compatible endpoint). Can also be changed at
# runtime from the Settings page in the app, without editing this file.
LLM_PROVIDER=ollama

# ===============================================
# ANTHROPIC CLAUDE API (used when LLM_PROVIDER=claude)
# ===============================================
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096

# ===============================================
# OLLAMA (used when LLM_PROVIDER=ollama, or always for local scoring/parsing)
# ===============================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ===============================================
# CUSTOM OPENAI-COMPATIBLE PROVIDER (used when LLM_PROVIDER=custom)
# ===============================================
# Any endpoint speaking OpenAI's /chat/completions + tool-calling format:
# OpenAI itself, OpenRouter, Groq, Together, a self-hosted vLLM/LM Studio
# server, etc.
# CUSTOM_LLM_BASE_URL=https://api.example.com/v1
# CUSTOM_LLM_API_KEY=your_key_here
# CUSTOM_LLM_MODEL=some-model

# ===============================================
# DATABASE
# ===============================================
# SQLite for local development (default)
DATABASE_URL=sqlite+aiosqlite:///data/healthsteward.db

# PostgreSQL for production (Phase 2+)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/healthsteward

# ===============================================
# LOGGING
# ===============================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=./logs/healthsteward.log
LOG_ROTATION=10 MB
LOG_RETENTION=7 days

# ===============================================
# APPLICATION SETTINGS
# ===============================================
APP_NAME=HealthSteward
APP_VERSION=0.1.0
API_HOST=0.0.0.0
API_PORT=8000

# ===============================================
# PHASE 2+ FEATURES (Not yet implemented)
# ===============================================

# --- Redis (Caching & Task Queue) ---
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=

# --- Vector Database (ChromaDB for RAG) ---
# CHROMA_HOST=localhost
# CHROMA_PORT=8001
# CHROMA_COLLECTION_NAME=health_documents

# --- Calendar Integration ---
# GOOGLE_CALENDAR_CREDENTIALS_PATH=./config/google_credentials.json
# GOOGLE_CALENDAR_TOKEN_PATH=./config/token.json
# USE_APPLE_CALENDAR=false

# --- Scheduling & Reminders ---
# HEALTH_INTERVIEW_SCHEDULE="0 20 * * *"
# MEDICATION_REMINDER_SCHEDULE="0 9,21 * * *"

# --- Privacy & Security ---
# ENCRYPTION_KEY=generate_a_secure_key_here
# SESSION_SECRET=generate_a_secure_session_secret

# --- ML Experiment Tracking ---
# WANDB_API_KEY=your_wandb_key_here
# WANDB_PROJECT=healthsteward
# WANDB_ENABLED=false
